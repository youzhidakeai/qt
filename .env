# ==========================================
# Matrix Quantitative Engine Configuration
# ==========================================

# 币安 U本位合约 API 凭证 (必填项)
BINANCE_API_KEY=""
BINANCE_API_SECRET=""
# Telegram 遥控机器人 Token (必填项)
TELOXIDE_TOKEN=""

# Telegram 消息接收人 Chat ID (必填项，用于接收全自动交易战报)
# 可以找机器人 @userinfobot 发送 /start 获取你的 Chat ID
TELEGRAM_CHAT_ID=""

# 日志输出级别
RUST_LOG=info

# ==========================================
# 科学上网代理配置 (中国大陆直连必填)
# ==========================================
# Telegram API (api.telegram.org) 在国内被墙，程序会报 Connect 错误 (-9806)
# 请填入你本地代理软件 (如 Clash, V2Ray, Surge 等) 的 HTTP 代理地址与端口
# 常见的默认端口：Clash(7890), V2Ray(10809), Surge(8281)
# HTTPS_PROXY=http://127.0.0.1:7890


REDIS_URL=redis://127.0.0.1:6379  

# 交易排行
TOP_SYMBOLS_COUNT=20                                                                                                                    
